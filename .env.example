# Copy to .env in repository root and adjust for your environment.
# Never commit .env or docker/secrets/*.txt

# --- Application ---
APP_ENV=local
APP_URL=http://localhost:8080
NODE_ENV=development
FLASK_ENV=development
SESSION_SECRET=change-me-to-a-long-random-string

# --- Edge / ports (host) ---
NGINX_HTTP_PORT=8080
POSTGRES_HOST_PORT=5433
AI_DEBUG_PORT=5001
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MAILPIT_UI_PORT=8025

# --- Database ---
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=rms
DB_USERNAME=rms
# DB_PASSWORD is supplied via docker/secrets/db_password.txt

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- AI service ---
AI_SERVICE_URL=http://ai-service:5000

# --- File storage (dev MinIO) ---
FILE_STORAGE_DRIVER=s3
S3_ENDPOINT=http://minio:9000
S3_BUCKET=rms-uploads
S3_ACCESS_KEY_ID=rmsminio
S3_SECRET_ACCESS_KEY=rmsminio-dev-change-me
S3_USE_PATH_STYLE_ENDPOINT=true

# --- MinIO (dev profile only) ---
MINIO_ROOT_USER=rmsminio
MINIO_ROOT_PASSWORD=rmsminio-dev-change-me

# --- Auth (set in Laravel when implemented) ---
# APP_KEY via docker/secrets/app_key.txt
# SANCTUM_STATEFUL_DOMAINS=localhost:8080
